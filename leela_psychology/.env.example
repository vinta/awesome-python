# ── Leela Quest+Psychology AI — environment template ──────────────────────────
# Copy to .env and fill in real secrets.  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# HMAC master key for session pseudonymisation (32 random bytes, base64url or hex)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
LEE_HMAC_KEY=CHANGE_ME_32_BYTE_HEX_OR_BASE64

# Fernet key for AES-GCM metadata encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LEE_FERNET_KEY=CHANGE_ME_FERNET_KEY

# Embedding backend: mock | local
# mock  — deterministic hash-based embeddings (no GPU, suitable for CI/dev)
# local — sentence-transformers (requires extra deps; see requirements.txt)
LEE_EMB_PROVIDER=mock
